# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Environment / secrets
.env
.env.*

# IDE
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Data (keep folder structure, ignore large downloaded files)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models / artifacts
models/
*.h5
*.keras
*.pkl
*.joblib

# Reports build artifacts
reports/*.pdf

# Local scratch / backup (not tracked)
backup/

# Interim report (kept local, not tracked)
reports/interim_report.*

# Unrelated coursework (kept local, not tracked)
conflict-resolution/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
